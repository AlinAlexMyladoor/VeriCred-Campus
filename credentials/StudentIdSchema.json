{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VeriCred Student ID",
  "description": "Verifiable Digital Student Identity",
  "type": "object",
  "properties": {
    "studentId": {
      "type": "string"
    },
    "fullName": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "program": {
      "type": "string"
    },
    "department": {
      "type": "string"
    },
    "semester": {
      "type": "integer"
    },
    "enrollmentStatus": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "GRADUATED",
        "SUSPENDED"
      ]
    }
  },
  "required": [
    "studentId",
    "fullName",
    "email",
    "program",
    "department",
    "semester",
    "enrollmentStatus"
  ]
}